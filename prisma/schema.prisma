generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductCategory {
  BEVERAGE
  SHELF
  OTHER
}

enum ExtraCategory {
  BEVERAGE
  SHELF
  OTHER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("CUSTOMER")
  phone         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  customerAppointments  Appointment[]          @relation("CustomerAppointments")
  barberAppointments    Appointment[]          @relation("BarberAppointments")
  customerReviews        Review[]              @relation("CustomerReviews")
  barberReviews          Review[]              @relation("BarberReviews")
  barberServices        Service[]              @relation("BarberServices")
  barberServiceCommissions BarberServiceCommission[]
  barberAvailabilities  BarberAvailability[]
  barberBlocks          BarberBlock[]
  recurringBarberBlocks RecurringBarberBlock[]
  barberPayouts         BarberPayout[]
  barberClientNotes     ClientNote[]           @relation("BarberClientNotes")
  customerClientNotes   ClientNote[]           @relation("CustomerClientNotes")
  customerProfile       CustomerProfile?       @relation("CustomerProfileOwner")
  preferredByProfiles   CustomerProfile[]      @relation("PreferredBarber")

  orders Order[] @relation("CustomerOrders")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PendingRegistration {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  role         String   @default("CUSTOMER")
  code         String
  expiresAt    DateTime
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email, expiresAt])
}

model PasswordResetRequest {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, expiresAt])
}

model Service {
  id              String   @id @default(cuid())
  barberId        String?
  name            String
  description     String?
  price           Float
  duration        Int
  bufferAfter     Int      @default(0)
  commissionType  String   @default("PERCENT")
  commissionValue Float    @default(40)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  barber           User?                @relation("BarberServices", fields: [barberId], references: [id], onDelete: Cascade)
  appointmentItems AppointmentService[]
  barberCommissions BarberServiceCommission[]

  @@index([barberId])
  @@index([barberId, isActive])
}

model Appointment {
  id         String   @id @default(cuid())
  customerId String
  barberId   String
  date       DateTime
  status     String   @default("PENDING")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer User                 @relation("CustomerAppointments", fields: [customerId], references: [id], onDelete: Cascade)
  barber   User                 @relation("BarberAppointments", fields: [barberId], references: [id], onDelete: Cascade)
  services AppointmentService[]
  items    AppointmentItem[]
  review   Review?

  @@index([customerId])
  @@index([barberId])
  @@index([date])
  @@index([barberId, status])
}

model AppointmentService {
  id                      String   @id @default(cuid())
  appointmentId           String
  serviceId               String
  orderIndex              Int      @default(0)
  nameSnapshot            String
  priceSnapshot           Float
  durationSnapshot        Int
  bufferAfter             Int      @default(0)
  commissionTypeSnapshot  String   @default("PERCENT")
  commissionValueSnapshot Float    @default(40)
  barberPayoutSnapshot    Float    @default(0)
  shopRevenueSnapshot     Float    @default(0)
  createdAt               DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([appointmentId, orderIndex])
  @@index([serviceId])
}

model Review {
  id            String   @id @default(cuid())
  appointmentId String   @unique
  customerId    String
  barberId      String
  rating        Int
  comment       String
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customer    User        @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)
  barber      User        @relation("BarberReviews", fields: [barberId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([barberId])
  @@index([isVisible, createdAt])
}

model BarberAvailability {
  id        String   @id @default(cuid())
  barberId  String
  weekDay   Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  barber User @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, weekDay])
  @@index([barberId, weekDay])
}

model BarberBlock {
  id            String   @id @default(cuid())
  barberId      String
  startDateTime DateTime
  endDateTime   DateTime
  reason        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  barber User @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId, startDateTime])
  @@index([barberId, endDateTime])
}

model RecurringBarberBlock {
  id        String   @id @default(cuid())
  barberId  String
  weekDay   Int
  startTime String
  endTime   String
  reason    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  barber User @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId, weekDay, isActive])
  @@index([barberId, isActive])
}

model ClientNote {
  id         String   @id @default(cuid())
  barberId   String
  customerId String
  note       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  barber   User @relation("BarberClientNotes", fields: [barberId], references: [id], onDelete: Cascade)
  customer User @relation("CustomerClientNotes", fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([barberId, customerId])
  @@index([barberId])
  @@index([customerId])
}

model CustomerProfile {
  id                String    @id @default(cuid())
  customerId        String    @unique
  birthDate         DateTime?
  preferredBarberId String?
  allergies         String?
  preferences       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  customer        User  @relation("CustomerProfileOwner", fields: [customerId], references: [id], onDelete: Cascade)
  preferredBarber User? @relation("PreferredBarber", fields: [preferredBarberId], references: [id], onDelete: SetNull)

  @@index([preferredBarberId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    ProductCategory @default(OTHER)
  price       Float
  imageUrl    String?
  imagePath   String?  @map("image_path")
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems        OrderItem[]
  stockMovements    StockMovement[]
}

model BarberServiceCommission {
  id              String   @id @default(cuid())
  barberId        String
  serviceId       String
  commissionType  String   @default("PERCENT")
  commissionValue Float    @default(40)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  barber  User    @relation(fields: [barberId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([barberId, serviceId])
  @@index([barberId])
  @@index([serviceId])
}

model ExtraProduct {
  id          String        @id @default(cuid())
  name        String
  description String?
  category    ExtraCategory @default(OTHER)
  price       Float
  commissionType  String   @default("PERCENT")
  commissionValue Float    @default(0)
  imageUrl    String?
  imagePath   String?       @map("image_path")
  stock       Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  appointmentItems AppointmentItem[]
  stockMovements   ExtraStockMovement[]
}

model AppointmentItem {
  id                  String   @id @default(cuid())
  appointmentId       String
  extraProductId      String   @map("productId")
  productNameSnapshot String
  quantity            Int      @default(1)
  unitPrice           Float
  subtotal            Float
  commissionTypeSnapshot  String @default("PERCENT")
  commissionValueSnapshot Float  @default(0)
  barberPayoutSnapshot    Float  @default(0)
  shopRevenueSnapshot     Float  @default(0)
  isDelivered         Boolean  @default(false)
  deliveredAt         DateTime?
  createdAt           DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  extraProduct ExtraProduct @relation(fields: [extraProductId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([extraProductId])
}

model Order {
  id              String   @id @default(cuid())
  customerId      String
  couponId        String?
  status          String   @default("PENDING")
  trackingCode    String?
  adminApproved   Boolean  @default(false)
  total           Float    @default(0)
  subtotal        Float    @default(0)
  shippingCost    Float    @default(0)
  discountTotal   Float    @default(0)
  shippingZipCode String?
  shippingMethod  String?
  shippingAddress String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer User        @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Cascade)
  coupon   Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items    OrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([couponId])
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  productId           String
  productNameSnapshot String
  quantity            Int      @default(1)
  unitPrice           Float
  createdAt           DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String?
  discountType  String
  discountValue Float
  minOrderTotal Float     @default(0)
  maxDiscount   Float?
  expiresAt     DateTime?
  usageLimit    Int?
  timesUsed     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders Order[]

  @@index([code, isActive])
}

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  type      String
  quantity  Int
  reason    String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([type])
}

model ExtraStockMovement {
  id             String   @id @default(cuid())
  extraProductId String
  type           String
  quantity       Int
  reason         String?
  createdAt      DateTime @default(now())

  extraProduct ExtraProduct @relation(fields: [extraProductId], references: [id], onDelete: Cascade)

  @@index([extraProductId, createdAt])
  @@index([type])
}

model BarberPayout {
  id              String    @id @default(cuid())
  barberId        String
  periodStart     DateTime
  periodEnd       DateTime
  grossRevenue    Float     @default(0)
  commissionTotal Float     @default(0)
  shopNetRevenue  Float     @default(0)
  status          String    @default("OPEN")
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  barber User @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, periodStart, periodEnd])
  @@index([barberId, status])
  @@index([periodStart, periodEnd])
}
