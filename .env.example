# Banco PostgreSQL/Supabase
# DATABASE_URL: use a URL do pooler de transacoes do Supabase.
# DIRECT_URL: use a URL direta/session pooler para migrations do Prisma.
DATABASE_URL="postgresql://postgres.PROJECT_REF:SUA_SENHA@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:SUA_SENHA@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="troque-essa-chave-por-uma-bem-grande"
AUTH_SECRET="troque-essa-chave-por-uma-bem-grande"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Storage para imagens publicas do catalogo
# A service role key deve ficar apenas no servidor.
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"
SUPABASE_STORAGE_BUCKET="product-images"

# Credenciais criadas pelo seed
ADMIN_EMAIL="admin@barbearia.com"
ADMIN_PASSWORD="123456"

# WhatsApp da barbearia em formato internacional, sem + nem espacos
BARBER_WHATSAPP_NUMBER="5511999999999"

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN="TEST-xxxxxxxxxxxxxxxx"
MERCADO_PAGO_WEBHOOK_SECRET="troque-se-quiser-validar-webhook"

# E-mail para verificacao de cadastro e recuperacao de senha
# Em desenvolvimento local, se estas variaveis ficarem vazias, o codigo aparece no log/tela.
# Gmail: use smtp.gmail.com e uma senha de app, nao a senha normal da conta.
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="jakcompanybarbearia@gmail.com"
EMAIL_SERVER_PASS="sua-senha-de-app-do-gmail"
